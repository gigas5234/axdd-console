[
  {
    "id": "kickoff-report-workunit",
    "name": "Kickoff Report Work Unit",
    "description": "프로젝트 착수 시 필요한 요약·보고서·검증을 자동 실행한다.",
    "triggerHooks": ["kickoff-report-hook"],
    "skills": [
      "simple-summary-skill",
      "kickoff-report-template-skill",
      "output-validation-skill"
    ],
    "input": ["project_brief.md"],
    "output": ["kickoff_report.md", "risk_log.md", "next_step.md"],
