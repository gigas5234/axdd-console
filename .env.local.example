# AXDD SkillOps Console — 환경변수 템플릿
# 이 파일을 복사해 .env.local 로 저장한 뒤 값을 채우세요.
#   PowerShell: Copy-Item .env.local.example .env.local
#   Bash:       cp .env.local.example .env.local

# === LLM (필수: 실제 동작 테스트하려면) ===
# https://console.anthropic.com 에서 발급
# 키가 비어 있거나 이 줄 자체가 없으면 자동으로 mock 폴백
ANTHROPIC_API_KEY=

# (옵션) 자체 호스팅 / 사내 프록시 사용 시
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# === Figma MCP (옵션) ===
# 사내 보안정책으로 MCP 직접 연결이 가능해지면 1로 변경
NEXT_PUBLIC_FIGMA_MCP_ENABLED=0
